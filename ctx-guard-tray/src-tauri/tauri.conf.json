{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ctx-guard",
  "version": "2.1.0",
  "identifier": "com.ctxguard.tray",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "ctx-guard",
        "width": 800,
        "height": 600,
        "visible": false
      },
      {
        "label": "float",
        "title": "ctx-guard",
        "width": 88,
        "height": 118,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "resizable": false,
        "x": 100,
        "y": 100,
        "url": "http://localhost:1420/float.html",
        "shadow": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "icons/icon-green.png": "icons/icon-green.png",
      "icons/icon-yellow.png": "icons/icon-yellow.png",
      "icons/icon-red.png": "icons/icon-red.png"
    }
  }
}